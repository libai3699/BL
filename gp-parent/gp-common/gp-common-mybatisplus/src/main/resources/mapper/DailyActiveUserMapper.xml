            <if test="parentUserId != null ">parent_user_id,</if>
            <if test="turnoverAmount != null ">turnover_amount,</if>
            <if test="isNew != null ">is_new,</if>
            <if test="activeDate != null ">active_date,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
            <if test="updateTime != null ">update_time,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null ">#{userId},</if>
            <if test="parentUserId != null ">#{parentUserId},</if>
            <if test="turnoverAmount != null ">#{turnoverAmount},</if>
            <if test="isNew != null ">#{isNew},</if>
