    <sql id="selectDailyActiveUserVo">
        select id, user_id,parent_user_id, turnover_amount, is_new, active_date, create_time, create_by, update_time, update_by from t_daily_active_user
    </sql>

    <select id="selectDailyActiveUserList" parameterType="com.gp.common.mybatisplus.entity.DailyActiveUser" resultMap="DailyActiveUserResult">
        <include refid="selectDailyActiveUserVo"/>
        <where>
            <if test="userId != null ">and user_id = #{userId}</if>
            <if test="parentUserId != null ">and parent_user_id = #{parentUserId}</if>
            <if test="turnoverAmount != null ">and turnover_amount = #{turnoverAmount}</if>
            <if test="isNew != null ">and is_new = #{isNew}</if>
            <if test="activeDates != null and activeDates.length > 0">
                and (
                <foreach collection="activeDates" item="item" index="index">
                    <if test="index == 0">
                        active_date between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="createTimes != null and createTimes.length > 0">
                and (
                <foreach collection="createTimes" item="item" index="index">
                    <if test="index == 0">
                        create_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="createBy != null  and createBy != ''">and create_by = #{createBy}</if>
            <if test="updateTimes != null and updateTimes.length > 0">
                and (
                <foreach collection="updateTimes" item="item" index="index">
                    <if test="index == 0">
                        update_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="updateBy != null  and updateBy != ''">and update_by = #{updateBy}</if>
        </where>
    </select>

    <select id="selectDailyActiveUserById" parameterType="Long" resultMap="DailyActiveUserResult">
        <include refid="selectDailyActiveUserVo"/>
        where id = #{id}
    </select>

    <insert id="insertDailyActiveUser" parameterType="com.gp.common.mybatisplus.entity.DailyActiveUser" useGeneratedKeys="true" keyProperty="id">
        insert into t_daily_active_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
