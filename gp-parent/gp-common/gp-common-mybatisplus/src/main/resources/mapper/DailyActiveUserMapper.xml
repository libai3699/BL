    </update>

    <insert id="insertOrUpdateData">
        INSERT INTO t_daily_active_user (
        user_id,
        is_new,
        parent_user_id,
        p_path,
        turnover_amount,
        active_date
        )
        VALUES (
        #{vo.userId},
        #{vo.isNew},
        #{vo.parentUserId},
        #{vo.pPath},
        #{vo.turnoverAmount},
        #{vo.activeDate}
        )
        ON DUPLICATE KEY UPDATE
        turnover_amount = turnover_amount + #{vo.turnoverAmount}
    </insert>

