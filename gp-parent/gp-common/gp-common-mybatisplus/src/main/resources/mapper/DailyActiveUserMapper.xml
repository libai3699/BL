    <insert id="insertOrUpdate" parameterType="com.gp.common.mybatisplus.entity.DailyActiveUser">

    </insert>

    <update id="updateDailyActiveUser" parameterType="com.gp.common.mybatisplus.entity.DailyActiveUser">
        update t_daily_active_user
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="parentUserId != null ">parent_user_id = #{parentUserId},</if>
            <if test="turnoverAmount != null ">turnover_amount = #{turnoverAmount},</if>
            <if test="isNew != null ">is_new = #{isNew},</if>
            <if test="activeDate != null ">active_date = #{activeDate},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteDailyActiveUserById" parameterType="Long">
        delete from t_daily_active_user where id = #{id}
    </delete>

    <delete id="deleteDailyActiveUserByIds" parameterType="String">
        delete from t_daily_active_user where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
