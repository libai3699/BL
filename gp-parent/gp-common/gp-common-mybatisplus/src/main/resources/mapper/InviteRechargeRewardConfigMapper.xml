<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.InviteRechargeRewardConfigMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.InviteRechargeRewardConfig" id="InviteRechargeRewardConfigResult">
        <result property="id"    column="id"    />
        <result property="rewardType"    column="reward_type"    />
        <result property="minRechargeAmount"    column="min_recharge_amount"    />
        <result property="rewardAmount"    column="reward_amount"    />
        <result property="withdrawBonusRatio"    column="withdraw_bonus_ratio"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectInviteRechargeRewardConfigVo">
        select id, reward_type, min_recharge_amount, reward_amount, withdraw_bonus_ratio, status, create_time, update_time from t_invite_recharge_reward_config
    </sql>

    <select id="selectInviteRechargeRewardConfigList" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardConfig" resultMap="InviteRechargeRewardConfigResult">
        <include refid="selectInviteRechargeRewardConfigVo"/>
        <where>
    <if test="rewardType != null "> and reward_type = #{rewardType}</if>
    <if test="minRechargeAmount != null "> and min_recharge_amount = #{minRechargeAmount}</if>
    <if test="rewardAmount != null "> and reward_amount = #{rewardAmount}</if>
    <if test="withdrawBonusRatio != null "> and withdraw_bonus_ratio = #{withdrawBonusRatio}</if>
    <if test="status != null "> and status = #{status}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
        </where>
    </select>

    <select id="selectInviteRechargeRewardConfigById" parameterType="Long" resultMap="InviteRechargeRewardConfigResult">
        <include refid="selectInviteRechargeRewardConfigVo"/>
        where id = #{id}
    </select>

    <insert id="insertInviteRechargeRewardConfig" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardConfig" useGeneratedKeys="true" keyProperty="id">
        insert into t_invite_recharge_reward_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="rewardType != null ">reward_type,</if>
            <if test="minRechargeAmount != null ">min_recharge_amount,</if>
            <if test="rewardAmount != null ">reward_amount,</if>
            <if test="withdrawBonusRatio != null ">withdraw_bonus_ratio,</if>
            <if test="status != null ">status,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="updateTime != null ">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="rewardType != null ">#{rewardType},</if>
            <if test="minRechargeAmount != null ">#{minRechargeAmount},</if>
            <if test="rewardAmount != null ">#{rewardAmount},</if>
            <if test="withdrawBonusRatio != null ">#{withdrawBonusRatio},</if>
            <if test="status != null ">#{status},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="updateTime != null ">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateInviteRechargeRewardConfig" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardConfig">
        update t_invite_recharge_reward_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="rewardType != null ">reward_type = #{rewardType},</if>
            <if test="minRechargeAmount != null ">min_recharge_amount = #{minRechargeAmount},</if>
            <if test="rewardAmount != null ">reward_amount = #{rewardAmount},</if>
            <if test="withdrawBonusRatio != null ">withdraw_bonus_ratio = #{withdrawBonusRatio},</if>
            <if test="status != null ">status = #{status},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteInviteRechargeRewardConfigById" parameterType="Long">
        delete from t_invite_recharge_reward_config where id = #{id}
    </delete>

    <delete id="deleteInviteRechargeRewardConfigByIds" parameterType="String">
        delete from t_invite_recharge_reward_config where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_invite_recharge_reward_config
    </update>

    <select id="selectEnabledConfigsOrderByAmountDesc" resultMap="InviteRechargeRewardConfigResult">
        <include refid="selectInviteRechargeRewardConfigVo"/>
        where status = 1 and reward_type = 1
        order by min_recharge_amount desc
    </select>

    <select id="selectEnabledDailyConfigsOrderByAmountDesc" resultMap="InviteRechargeRewardConfigResult">
        <include refid="selectInviteRechargeRewardConfigVo"/>
        where status = 1 and reward_type = 2
        order by min_recharge_amount desc
    </select>
</mapper>
