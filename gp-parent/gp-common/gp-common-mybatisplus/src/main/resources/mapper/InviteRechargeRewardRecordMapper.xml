<mapper namespace="com.gp.common.mybatisplus.mapper.InviteRechargeRewardRecordMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.InviteRechargeRewardRecord" id="InviteRechargeRewardRecordResult">
        <result property="id"    column="id"    />
        <result property="inviterUserId"    column="inviter_user_id"    />
        <result property="inviteeUserId"    column="invitee_user_id"    />
        <result property="rewardType"    column="reward_type"    />
        <result property="bizDate"    column="biz_date"    />
        <result property="rechargeAmount"    column="recharge_amount"    />
        <result property="rewardAmount"    column="reward_amount"    />
        <result property="withdrawBetAmount"    column="withdraw_bet_amount"    />
        <result property="configId"    column="config_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="status"    column="status"    />
        <result property="retryCount"    column="retry_count"    />
        <result property="failReason"    column="fail_reason"    />
        <result property="grantTime"    column="grant_time"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectInviteRechargeRewardRecordVo">
        select id, inviter_user_id, invitee_user_id, reward_type, biz_date, recharge_amount, reward_amount, withdraw_bet_amount, config_id, order_no, status, retry_count, fail_reason, grant_time, create_time from t_invite_recharge_reward_record
    </sql>

    <select id="selectInviteRechargeRewardRecordList" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardRecord" resultMap="InviteRechargeRewardRecordResult">
        <include refid="selectInviteRechargeRewardRecordVo"/>
        <where>
    <if test="inviterUserId != null "> and inviter_user_id = #{inviterUserId}</if>
    <if test="inviteeUserId != null "> and invitee_user_id = #{inviteeUserId}</if>
    <if test="rewardType != null "> and reward_type = #{rewardType}</if>
    <if test="bizDate != null "> and biz_date = #{bizDate}</if>
    <if test="rechargeAmount != null "> and recharge_amount = #{rechargeAmount}</if>
    <if test="rewardAmount != null "> and reward_amount = #{rewardAmount}</if>
    <if test="withdrawBetAmount != null "> and withdraw_bet_amount = #{withdrawBetAmount}</if>
    <if test="configId != null "> and config_id = #{configId}</if>
    <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
    <if test="status != null "> and status = #{status}</if>
    <if test="retryCount != null "> and retry_count = #{retryCount}</if>
    <if test="failReason != null  and failReason != ''"> and fail_reason = #{failReason}</if>
    <if test="grantTimes != null and grantTimes.length > 0">
        and (
        <foreach collection="grantTimes" item="item" index="index">
            <if test="index == 0">
                grant_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
        </where>
    </select>

    <select id="selectInviteRechargeRewardRecordById" parameterType="Long" resultMap="InviteRechargeRewardRecordResult">
        <include refid="selectInviteRechargeRewardRecordVo"/>
        where id = #{id}
    </select>

    <insert id="insertInviteRechargeRewardRecord" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardRecord" useGeneratedKeys="true" keyProperty="id">
        insert into t_invite_recharge_reward_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="inviterUserId != null ">inviter_user_id,</if>
            <if test="inviteeUserId != null ">invitee_user_id,</if>
            <if test="rewardType != null ">reward_type,</if>
            <if test="bizDate != null ">biz_date,</if>
            <if test="rechargeAmount != null ">recharge_amount,</if>
            <if test="rewardAmount != null ">reward_amount,</if>
            <if test="withdrawBetAmount != null ">withdraw_bet_amount,</if>
            <if test="configId != null ">config_id,</if>
            <if test="orderNo != null  and orderNo != ''">order_no,</if>
            <if test="status != null ">status,</if>
            <if test="retryCount != null ">retry_count,</if>
            <if test="failReason != null  and failReason != ''">fail_reason,</if>
            <if test="grantTime != null ">grant_time,</if>
            <if test="createTime != null ">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="inviterUserId != null ">#{inviterUserId},</if>
            <if test="inviteeUserId != null ">#{inviteeUserId},</if>
            <if test="rewardType != null ">#{rewardType},</if>
