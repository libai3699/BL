    </update>

    <delete id="deleteInviteRechargeRewardRecordById" parameterType="Long">
        delete from t_invite_recharge_reward_record where id = #{id}
    </delete>

    <delete id="deleteInviteRechargeRewardRecordByIds" parameterType="String">
        delete from t_invite_recharge_reward_record where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_invite_recharge_reward_record
    </update>

    <select id="selectInviteRechargeRewardRecordListCount" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardRecord" resultType="int">
        select count(1) from t_invite_recharge_reward_record
        <where>
            <if test="inviterUserId != null "> and inviter_user_id = #{inviterUserId}</if>
            <if test="inviteeUserId != null "> and invitee_user_id = #{inviteeUserId}</if>
            <if test="rewardType != null "> and reward_type = #{rewardType}</if>
            <if test="bizDate != null "> and biz_date = #{bizDate}</if>
            <if test="rechargeAmount != null "> and recharge_amount = #{rechargeAmount}</if>
            <if test="rewardAmount != null "> and reward_amount = #{rewardAmount}</if>
            <if test="withdrawBetAmount != null "> and withdraw_bet_amount = #{withdrawBetAmount}</if>
            <if test="configId != null "> and config_id = #{configId}</if>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="retryCount != null "> and retry_count = #{retryCount}</if>
            <if test="failReason != null  and failReason != ''"> and fail_reason = #{failReason}</if>
            <if test="createTimes != null and createTimes.length > 0">
                and (
                <foreach collection="createTimes" item="item" index="index">
                    <if test="index == 0">
                        create_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
        </where>
    </select>

    <select id="selectPendingRecords" resultMap="InviteRechargeRewardRecordResult">
        <include refid="selectInviteRechargeRewardRecordVo"/>
        where status = 0 and retry_count &lt; #{maxRetry}
        order by id asc
    </select>

    <!-- 已发放 status=1，按 grant_time 统计（与 MQ 发放时点一致） -->
    <select id="statInviteRewardByInviter" resultType="java.util.Map">
        SELECT IFNULL(SUM(reward_amount), 0) AS rewardAmount,
               COUNT(1) AS grantCount
        FROM t_invite_recharge_reward_record
        WHERE status = 1
          AND inviter_user_id = #{userId}
          AND grant_time BETWEEN #{startTime} AND #{endTime}
    </select>

    <select id="statInviteRewardByChannel" resultType="java.util.Map">
        SELECT IFNULL(SUM(r.reward_amount), 0) AS rewardAmount,
               COUNT(1) AS grantCount
        FROM t_invite_recharge_reward_record r
        INNER JOIN t_user u ON r.inviter_user_id = u.user_id
        WHERE r.status = 1
          AND u.channel_id = #{channelId}
          AND r.grant_time BETWEEN #{startTime} AND #{endTime}
    </select>

    <select id="statInviteRewardAll" resultType="java.util.Map">
        SELECT IFNULL(SUM(reward_amount), 0) AS rewardAmount,
               COUNT(1) AS grantCount
        FROM t_invite_recharge_reward_record
        WHERE status = 1
          AND grant_time BETWEEN #{startTime} AND #{endTime}
    </select>

    <!-- 自然日充值：在线支付已支付 + 人工上分 -->
    <select id="listUserRechargeSumByDay" resultType="com.gp.common.mybatisplus.vo.InviteeDayRechargeSumVO">
        SELECT user_id AS userId, IFNULL(SUM(amt), 0) AS totalAmount
        FROM (
            SELECT user_id, IFNULL(amount, 0) AS amt
            FROM t_order_amount
            WHERE order_status = 1
              AND pay_time &gt;= #{startTime}
              AND pay_time &lt;= #{endTime}
            UNION ALL
            SELECT user_id, IFNULL(amount, 0) AS amt
            FROM t_order_person
            WHERE order_type = 1
              AND create_time &gt;= #{startTime}
              AND create_time &lt;= #{endTime}
        ) t
        GROUP BY user_id
        HAVING IFNULL(SUM(amt), 0) &gt; 0
    </select>
</mapper>
