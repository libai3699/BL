            <if test="withdrawBetAmount != null ">#{withdrawBetAmount},</if>
            <if test="configId != null ">#{configId},</if>
            <if test="orderNo != null  and orderNo != ''">#{orderNo},</if>
            <if test="status != null ">#{status},</if>
            <if test="retryCount != null ">#{retryCount},</if>
            <if test="failReason != null  and failReason != ''">#{failReason},</if>
            <if test="grantTime != null ">#{grantTime},</if>
            <if test="createTime != null ">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateInviteRechargeRewardRecord" parameterType="com.gp.common.mybatisplus.entity.InviteRechargeRewardRecord">
        update t_invite_recharge_reward_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="inviterUserId != null ">inviter_user_id = #{inviterUserId},</if>
            <if test="inviteeUserId != null ">invitee_user_id = #{inviteeUserId},</if>
            <if test="rewardType != null ">reward_type = #{rewardType},</if>
            <if test="bizDate != null ">biz_date = #{bizDate},</if>
            <if test="rechargeAmount != null ">recharge_amount = #{rechargeAmount},</if>
            <if test="rewardAmount != null ">reward_amount = #{rewardAmount},</if>
            <if test="withdrawBetAmount != null ">withdraw_bet_amount = #{withdrawBetAmount},</if>
            <if test="configId != null ">config_id = #{configId},</if>
            <if test="orderNo != null  and orderNo != ''">order_no = #{orderNo},</if>
            <if test="status != null ">status = #{status},</if>
            <if test="retryCount != null ">retry_count = #{retryCount},</if>
            <if test="failReason != null  and failReason != ''">fail_reason = #{failReason},</if>
            <if test="grantTime != null ">grant_time = #{grantTime},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
        </trim>
