    <sql id="selectMerchantChangeVo">
        select id, merchant_id, merchant_name, user_id, tg_user_id, currency_id, item_id, chain_tag, item_name, order_no, order_type, exchange_type, account_type, type, amount, old_amount, new_amount, remark, operator, sign_time, sign, create_time from t_merchant_change
    </sql>

    <select id="selectMerchantChangeList" parameterType="com.gp.common.mybatisplus.entity.MerchantChange" resultMap="MerchantChangeResult">
        <include refid="selectMerchantChangeVo"/>
        <where>
    <if test="merchantId != null "> and merchant_id = #{merchantId}</if>
            <if test="merchantName != null  and merchantName != ''"> and merchant_name like concat('%', #{merchantName}, '%')</if>
    <if test="userId != null "> and user_id = #{userId}</if>
    <if test="tgUserId != null "> and tg_user_id = #{tgUserId}</if>
    <if test="currencyId != null "> and currency_id = #{currencyId}</if>
    <if test="itemId != null "> and item_id = #{itemId}</if>
    <if test="chainTag != null  and chainTag != ''"> and chain_tag = #{chainTag}</if>
            <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
    <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
    <if test="orderType != null "> and order_type = #{orderType}</if>
    <if test="exchangeType != null "> and exchange_type = #{exchangeType}</if>
    <if test="accountType != null "> and account_type = #{accountType}</if>
    <if test="type != null "> and type = #{type}</if>
    <if test="amount != null "> and amount = #{amount}</if>
    <if test="oldAmount != null "> and old_amount = #{oldAmount}</if>
    <if test="newAmount != null "> and new_amount = #{newAmount}</if>
    <if test="operator != null  and operator != ''"> and operator = #{operator}</if>
    <if test="signTime != null "> and sign_time = #{signTime}</if>
    <if test="sign != null  and sign != ''"> and sign = #{sign}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
        </where>
    </select>

    <select id="selectMerchantChangeById" parameterType="Long" resultMap="MerchantChangeResult">
        <include refid="selectMerchantChangeVo"/>
        where id = #{id}
    </select>

