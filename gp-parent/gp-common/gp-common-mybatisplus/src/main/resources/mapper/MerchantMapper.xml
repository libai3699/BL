               email_alias, remark, sign_time, sign, create_time, update_time, update_by, create_by, domain_name, code,audio_withdraw,audio_law,platform_description, invite_description from t_merchant
    </sql>
    <select id="selectMerchantList" parameterType="com.gp.common.mybatisplus.entity.Merchant"
            resultMap="MerchantResult">
        <include refid="selectMerchantVo"/>
        <where>
            <if test="merchantName != null  and merchantName != ''">and merchant_name like concat('%', #{merchantName},
                '%')
            </if>
            <if test="amount != null ">and amount = #{amount}</if>
            <if test="signTime != null ">and sign_time = #{signTime}</if>
            <if test="merchantId != null  and merchantId != ''">and merchant_id = #{merchantId}</if>
            <if test="sign != null  and sign != ''">and sign = #{sign}</if>
            <if test="createTimes != null and createTimes.length > 0">
                and (
                <foreach collection="createTimes" item="item" index="index">
                    <if test="index == 0">
                        create_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="updateTimes != null and updateTimes.length > 0">
                and (
                <foreach collection="updateTimes" item="item" index="index">
                    <if test="index == 0">
                        update_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="updateBy != null  and updateBy != ''">and update_by = #{updateBy}</if>
            <if test="createBy != null  and createBy != ''">and create_by = #{createBy}</if>
            <if test="status != null ">and status = #{status}</if>
            <if test="domainName != null  and domainName != ''">and domain_name = #{domainName}</if>
            <if test="code != null  and code != ''">and code = #{code}</if>
            <if test="platformDescription != null  and platformDescription != ''">and platform_description = #{platformDescription}</if>
            <if test="inviteDescription != null  and inviteDescription != ''">and invite_description = #{inviteDescription}</if>
        </where>
    </select>

    <select id="selectMerchantById" parameterType="Long" resultMap="MerchantResult">
        <include refid="selectMerchantVo"/>
        where merchant_id = #{merchantId}
    </select>

