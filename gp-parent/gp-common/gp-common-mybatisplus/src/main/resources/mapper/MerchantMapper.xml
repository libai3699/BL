    <sql id="selectMerchantVo">
        select merchant_id, merchant_name, amount, status, logo, soccer_report, wheel_pic, activity_pic, recharge_pic, withdraw_pic, down_money_pic,
               level_up_pic_v2, level_up_pic_v3, level_up_pic_v4, level_up_pic_v5,level_up_pic_v6, level_up_pic_v7, level_up_pic_v8, level_up_pic_v9, level_up_pic_v10,start_logo,
