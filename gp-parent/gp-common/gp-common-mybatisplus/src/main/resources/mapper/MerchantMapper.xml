    </delete>

    <delete id="deleteMerchantByIds" parameterType="String">
        delete from t_merchant where merchant_id in
        <foreach item="merchantId" collection="array" open="(" separator="," close=")">
            #{merchantId}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_merchant
    </update>
    <update id="upScoreByMerchantId">
        update t_merchant
        set amount    = amount + #{amount},
            sign_time = #{signTime},
            sign      = TO_BASE64(MD5((CONCAT(MD5(CONCAT(code, '&amp;', domain_name,'&amp;', TRIM(TRAILING '.' from (TRIM(TRAILING '0' FROM amount))),
                               '&amp;', #{signTime}, #{signSecretKey})), #{signSecretKey}))))
        where merchant_id = #{merchantId}
    </update>
