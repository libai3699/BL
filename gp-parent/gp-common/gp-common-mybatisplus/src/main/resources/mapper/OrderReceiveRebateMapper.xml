        </foreach>
    </delete>

    <select id="sumClaimedAgentSalaryByChannel" resultType="java.math.BigDecimal">
        SELECT IFNULL(SUM(r.amount), 0)
        FROM t_order_receive_rebate r
                 INNER JOIN t_user u ON r.user_id = u.user_id
        WHERE r.record_type = 3
          AND r.create_time BETWEEN #{startTime} AND #{endTime}
          AND u.channel_id = #{channelId}
          AND r.currency_id = #{currencyId}
    </select>

    <select id="sumClaimedAgentSalaryByDayCurrency" resultType="java.math.BigDecimal">
        SELECT IFNULL(SUM(r.amount), 0)
        FROM t_order_receive_rebate r
        WHERE r.record_type = 3
          AND r.create_time BETWEEN #{startTime} AND #{endTime}
          AND r.currency_id = #{currencyId}
    </select>

    <select id="sumClaimedAgentSalaryByUser" resultType="java.math.BigDecimal">
        SELECT IFNULL(SUM(r.amount), 0)
        FROM t_order_receive_rebate r
        WHERE r.record_type = 3
          AND r.create_time BETWEEN #{startTime} AND #{endTime}
          AND r.user_id = #{userId}
          AND r.currency_id = #{currencyId}
