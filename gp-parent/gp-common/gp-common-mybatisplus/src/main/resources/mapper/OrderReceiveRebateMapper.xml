    <sql id="selectOrderReceiveRebateVo">
        select id, order_no, user_id, tg_user_id, currency_id, item_id, chain_tag, item_name, amount, record_type, create_time from t_order_receive_rebate
    </sql>

    <select id="selectOrderReceiveRebateList" parameterType="com.gp.common.mybatisplus.entity.OrderReceiveRebate" resultMap="OrderReceiveRebateResult">
        <include refid="selectOrderReceiveRebateVo"/>
        <where>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="tgUserId != null "> and tg_user_id = #{tgUserId}</if>
            <if test="currencyId != null "> and currency_id = #{currencyId}</if>
            <if test="itemId != null "> and item_id = #{itemId}</if>
            <if test="chainTag != null  and chainTag != ''"> and chain_tag = #{chainTag}</if>
                    <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="recordType != null "> and record_type = #{recordType}</if>
            <if test="createTimes != null and createTimes.length > 0">
                and (
                <foreach collection="createTimes" item="item" index="index">
                    <if test="index == 0">
                        create_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
        </where>
    </select>
    
    <select id="selectOrderReceiveRebateListCount" parameterType="com.gp.common.mybatisplus.entity.OrderReceiveRebate" resultType="java.lang.Integer">
        select count(*) from (
            <include refid="selectOrderReceiveRebateVo"/>
            <where>
                <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
                <if test="userId != null "> and user_id = #{userId}</if>
                <if test="tgUserId != null "> and tg_user_id = #{tgUserId}</if>
                <if test="currencyId != null "> and currency_id = #{currencyId}</if>
                <if test="itemId != null "> and item_id = #{itemId}</if>
                <if test="chainTag != null  and chainTag != ''"> and chain_tag = #{chainTag}</if>
                        <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
                <if test="amount != null "> and amount = #{amount}</if>
                <if test="recordType != null "> and record_type = #{recordType}</if>
                <if test="createTimes != null and createTimes.length > 0">
                    and (
                    <foreach collection="createTimes" item="item" index="index">
                        <if test="index == 0">
                            create_time between #{item,jdbcType=VARCHAR}
                        </if>
                        <if test="index == 1">
                            and #{item,jdbcType=VARCHAR}
                        </if>
                    </foreach>
                    )
                </if>
            </where>
        ) as tmp
    </select>

    <select id="selectOrderReceiveRebateById" parameterType="Long" resultMap="OrderReceiveRebateResult">
