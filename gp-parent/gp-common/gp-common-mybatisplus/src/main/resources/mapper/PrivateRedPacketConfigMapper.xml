<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.PrivateRedPacketConfigMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.PrivateRedPacketConfig" id="PrivateRedPacketConfigResult">
        <result property="id"    column="id"    />
        <result property="level"    column="level"    />
        <result property="dayBetAmount"    column="day_bet_amount"    />
        <result property="withdrawBonusRatio"    column="withdraw_bonus_ratio"    />
        <result property="targetUserIds"    column="target_user_ids"    />
        <result property="minRechargeAmount"    column="min_recharge_amount"    />
        <result property="status"    column="status"    />
        <result property="json"    column="json"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="typeCodeBet"    column="type_code_bet"    />
        <result property="rechargeType"    column="recharge_type"    />
    </resultMap>

    <sql id="selectPrivateRedPacketConfigVo">
        select id, level, day_bet_amount, withdraw_bonus_ratio, target_user_ids, min_recharge_amount, status, json, create_time, update_time, remark, type_code_bet, recharge_type from t_private_red_packet_config
    </sql>

    <select id="selectPrivateRedPacketConfigList" parameterType="com.gp.common.mybatisplus.entity.PrivateRedPacketConfig" resultMap="PrivateRedPacketConfigResult">
        <include refid="selectPrivateRedPacketConfigVo"/>
        <where>
    <if test="level != null "> and level = #{level}</if>
    <if test="dayBetAmount != null "> and day_bet_amount = #{dayBetAmount}</if>
    <if test="withdrawBonusRatio != null "> and withdraw_bonus_ratio = #{withdrawBonusRatio}</if>
    <if test="targetUserIds != null  and targetUserIds != ''"> and target_user_ids = #{targetUserIds}</if>
    <if test="minRechargeAmount != null "> and min_recharge_amount = #{minRechargeAmount}</if>
    <if test="status != null "> and status = #{status}</if>
    <if test="json != null  and json != ''"> and json = #{json}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="typeCodeBet != null  and typeCodeBet != ''"> and type_code_bet = #{typeCodeBet}</if>
    <if test="rechargeType != null "> and recharge_type = #{rechargeType}</if>
        </where>
    </select>

    <select id="selectPrivateRedPacketConfigById" parameterType="Long" resultMap="PrivateRedPacketConfigResult">
        <include refid="selectPrivateRedPacketConfigVo"/>
        where id = #{id}
    </select>

    <insert id="insertPrivateRedPacketConfig" parameterType="com.gp.common.mybatisplus.entity.PrivateRedPacketConfig" useGeneratedKeys="true" keyProperty="id">
        insert into t_private_red_packet_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="level != null ">level,</if>
            <if test="dayBetAmount != null ">day_bet_amount,</if>
            <if test="withdrawBonusRatio != null ">withdraw_bonus_ratio,</if>
            <if test="targetUserIds != null  and targetUserIds != ''">target_user_ids,</if>
            <if test="minRechargeAmount != null ">min_recharge_amount,</if>
            <if test="status != null ">status,</if>
            <if test="json != null  and json != ''">json,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="updateTime != null ">update_time,</if>
            <if test="remark != null  and remark != ''">remark,</if>
            <if test="typeCodeBet != null  and typeCodeBet != ''">type_code_bet,</if>
            <if test="rechargeType != null ">recharge_type,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="level != null ">#{level},</if>
            <if test="dayBetAmount != null ">#{dayBetAmount},</if>
            <if test="withdrawBonusRatio != null ">#{withdrawBonusRatio},</if>
            <if test="targetUserIds != null  and targetUserIds != ''">#{targetUserIds},</if>
            <if test="minRechargeAmount != null ">#{minRechargeAmount},</if>
            <if test="status != null ">#{status},</if>
            <if test="json != null  and json != ''">#{json},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="updateTime != null ">#{updateTime},</if>
            <if test="remark != null  and remark != ''">#{remark},</if>
            <if test="typeCodeBet != null  and typeCodeBet != ''">#{typeCodeBet},</if>
            <if test="rechargeType != null ">#{rechargeType},</if>
         </trim>
    </insert>

    <update id="updatePrivateRedPacketConfig" parameterType="com.gp.common.mybatisplus.entity.PrivateRedPacketConfig">
        update t_private_red_packet_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="level != null ">level = #{level},</if>
            <if test="dayBetAmount != null ">day_bet_amount = #{dayBetAmount},</if>
            <if test="withdrawBonusRatio != null ">withdraw_bonus_ratio = #{withdrawBonusRatio},</if>
            <if test="targetUserIds != null  and targetUserIds != ''">target_user_ids = #{targetUserIds},</if>
            <if test="minRechargeAmount != null ">min_recharge_amount = #{minRechargeAmount},</if>
            <if test="status != null ">status = #{status},</if>
            <if test="json != null  and json != ''">json = #{json},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="remark != null  and remark != ''">remark = #{remark},</if>
            <if test="typeCodeBet != null  and typeCodeBet != ''">type_code_bet = #{typeCodeBet},</if>
            <if test="rechargeType != null ">recharge_type = #{rechargeType},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePrivateRedPacketConfigById" parameterType="Long">
        delete from t_private_red_packet_config where id = #{id}
    </delete>

    <delete id="deletePrivateRedPacketConfigByIds" parameterType="String">
        delete from t_private_red_packet_config where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_private_red_packet_config
    </update>

    <select id="queryPrivateRedPacketConfigs" resultMap="PrivateRedPacketConfigResult">
        <include refid="selectPrivateRedPacketConfigVo"/>
        where status = 1
        and #{userLevel} >= level
        and #{codeAmount} >= day_bet_amount
        and #{rechargeAmount} >= min_recharge_amount
        and (
            target_user_ids is null
            or target_user_ids = ''
            or FIND_IN_SET(#{usrId}, target_user_ids) > 0
        )
        order by level desc, day_bet_amount desc
    </select>

    <select id="queryPrivateRedPacketConfig" resultMap="PrivateRedPacketConfigResult">
        <include refid="selectPrivateRedPacketConfigVo"/>
        where status = 1
        and #{userLevel} >= level
        and id =#{privateRedId}
        and #{codeAmount} >= day_bet_amount
        and #{rechargeAmount} >= min_recharge_amount
        and (
        target_user_ids is null
        or target_user_ids = ''
        or FIND_IN_SET(#{usrId}, target_user_ids) > 0
        )
        order by level desc, day_bet_amount desc
    </select>
    <!-- 查询私人红包列表（不过滤充值条件和游戏类型打码量，在Java层动态过滤） -->
    <select id="queryPrivateRedPacketConfigList" resultMap="PrivateRedPacketConfigResult">
        <include refid="selectPrivateRedPacketConfigVo"/>
        where status = 1
        and #{userLevel} >= level
        and (
        target_user_ids is null
        or target_user_ids = ''
        or FIND_IN_SET(#{usrId}, target_user_ids) > 0
        )
        order by level desc, day_bet_amount desc
    </select>
</mapper>
