    <select id="queryRedPacketRainConfig" resultMap="RedPacketRainConfigResult">
        <include refid="selectRedPacketRainConfigVo"/>
        where status = 1
        and start_time &lt; now()
        and end_time &gt; now()
        and #{userLevel} >= level
        and #{codeAmount} >= day_bet_amount
        and #{rechargeAmount} >= min_recharge_amount
        order by id desc
        limit 1
    </select>
