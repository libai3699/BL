<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.SystemMessageMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.SystemMessage" id="SystemMessageResult">
        <result property="id"    column="id"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="lanKey"    column="lan_key"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectSystemMessageVo">
        select id, title, content, lan_key, create_by, create_time, update_by, update_time from t_system_message
    </sql>

    <select id="selectSystemMessageList" parameterType="com.gp.common.mybatisplus.entity.SystemMessage" resultMap="SystemMessageResult">
        <include refid="selectSystemMessageVo"/>
        <where>
    <if test="title != null  and title != ''"> and title = #{title}</if>
    <if test="content != null  and content != ''"> and content = #{content}</if>
    <if test="lanKey != null  and lanKey != ''"> and lan_key = #{lanKey}</if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
        </where>
    </select>

    <select id="selectSystemMessageById" parameterType="Long" resultMap="SystemMessageResult">
        <include refid="selectSystemMessageVo"/>
        where id = #{id}
    </select>

    <insert id="insertSystemMessage" parameterType="com.gp.common.mybatisplus.entity.SystemMessage" useGeneratedKeys="true" keyProperty="id">
        insert into t_system_message
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null  and title != ''">title,</if>
            <if test="content != null  and content != ''">content,</if>
            <if test="lanKey != null  and lanKey != ''">lan_key,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
            <if test="updateTime != null ">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null  and title != ''">#{title},</if>
            <if test="content != null  and content != ''">#{content},</if>
            <if test="lanKey != null  and lanKey != ''">#{lanKey},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="updateBy != null  and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null ">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateSystemMessage" parameterType="com.gp.common.mybatisplus.entity.SystemMessage">
        update t_system_message
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null  and title != ''">title = #{title},</if>
            <if test="content != null  and content != ''">content = #{content},</if>
            <if test="lanKey != null  and lanKey != ''">lan_key = #{lanKey},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSystemMessageById" parameterType="Long">
        delete from t_system_message where id = #{id}
    </delete>

    <delete id="deleteSystemMessageByIds" parameterType="String">
        delete from t_system_message where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_system_message
    </update>
</mapper>
