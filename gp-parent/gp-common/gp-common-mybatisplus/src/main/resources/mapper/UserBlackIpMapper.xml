<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.UserBlackIpMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.UserBlackIp" id="UserBlackIpResult">
        <result property="id"    column="id"    />
        <result property="ip"    column="ip"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
    </resultMap>

    <sql id="selectUserBlackIpVo">
        select id, ip, remark, create_time, update_time, create_by, update_by from t_user_black_ip
    </sql>

    <select id="selectUserBlackIpList" parameterType="com.gp.common.mybatisplus.entity.UserBlackIp" resultMap="UserBlackIpResult">
        <include refid="selectUserBlackIpVo"/>
        <where>
    <if test="ip != null  and ip != ''"> and ip = #{ip}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
        </where>
    </select>

    <select id="selectUserBlackIpById" parameterType="Long" resultMap="UserBlackIpResult">
        <include refid="selectUserBlackIpVo"/>
        where id = #{id}
    </select>

    <insert id="insertUserBlackIp" parameterType="com.gp.common.mybatisplus.entity.UserBlackIp" useGeneratedKeys="true" keyProperty="id">
        insert into t_user_black_ip
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ip != null  and ip != ''">ip,</if>
            <if test="remark != null  and remark != ''">remark,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="updateTime != null ">update_time,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ip != null  and ip != ''">#{ip},</if>
            <if test="remark != null  and remark != ''">#{remark},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="updateTime != null ">#{updateTime},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
            <if test="updateBy != null  and updateBy != ''">#{updateBy},</if>
         </trim>
    </insert>

    <update id="updateUserBlackIp" parameterType="com.gp.common.mybatisplus.entity.UserBlackIp">
        update t_user_black_ip
        <trim prefix="SET" suffixOverrides=",">
            <if test="ip != null  and ip != ''">ip = #{ip},</if>
            <if test="remark != null  and remark != ''">remark = #{remark},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUserBlackIpById" parameterType="Long">
        delete from t_user_black_ip where id = #{id}
    </delete>

    <delete id="deleteUserBlackIpByIds" parameterType="String">
        delete from t_user_black_ip where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_user_black_ip
    </update>
</mapper>
