         </trim>
    </insert>

    <update id="updateUserWallet" parameterType="com.gp.common.mybatisplus.entity.UserWallet">
        update t_user_wallet
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="userTgId != null ">user_tg_id = #{userTgId},</if>
            <if test="userTgName != null  and userTgName != ''">user_tg_name = #{userTgName},</if>
            <if test="userTgUsername != null  and userTgUsername != ''">user_tg_username = #{userTgUsername},</if>
            <if test="currencyId != null ">currency_id = #{currencyId},</if>
            <if test="itemId != null ">item_id = #{itemId},</if>
            <if test="chainTag != null  and chainTag != ''">chain_tag = #{chainTag},</if>
            <if test="amount != null ">amount = #{amount},</if>
            <if test="maskAddr != null  and maskAddr != ''">mask_addr = #{maskAddr},</if>
            <if test="salt != null  and salt != ''">salt = #{salt},</if>
            <if test="signTime != null ">sign_time = #{signTime},</if>
            <if test="sign != null  and sign != ''">sign = #{sign},</if>
            <if test="lastAmountId != null ">last_amount_id = #{lastAmountId},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUserWalletById" parameterType="Long">
        delete from t_user_wallet where id = #{id}
    </delete>

    <delete id="deleteUserWalletByIds" parameterType="String">
        delete from t_user_wallet where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_user_wallet
    </update>


