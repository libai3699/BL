    <select id="countChannelAmount" resultType="java.math.BigDecimal">
        select
        ifnull(sum(w.amount), 0.0000) as userAmount
        from `t_user_wallet` w
        left join t_user u  on u.user_id = w.user_id
        WHERE
            u.channel_id = #{channelId}
    </select>

    <select id="countOrderAmount" resultType="java.math.BigDecimal">
        select
        ifnull(sum(amount), 0.0000) as userAmount
        from `t_user_wallet`
        where currency_id = #{currencyId}
    </select>

    <select id="findWalletIdList" resultType="com.gp.common.mybatisplus.entity.TUser">
        select u.*
        from t_user_wallet w
                 left join t_user u on u.user_id = w.user_id
        where u.lan_key = #{lanKey}
    </select>
    <select id="countChannelAndOrderAmount" resultType="java.util.Map">
        SELECT
            (SELECT IFNULL(SUM(w.amount), 0)
             FROM t_user_wallet w
                      JOIN t_user u ON w.user_id = u.user_id
             WHERE u.channel_id = #{channelId}
               AND w.currency_id = #{currencyId}) AS channelAmount,

            (SELECT IFNULL(SUM(amount), 0)
             FROM t_user_wallet
             WHERE currency_id = #{currencyId}) AS orderAmount

    </select>
    <select id="countOrderAmountByUserIds" resultType="java.math.BigDecimal">
        select
        ifnull(sum(amount), 0.0000) as userAmount
        from `t_user_wallet`
        where currency_id = #{currencyId}
        and user_id in
        <foreach item="userId" index="index" collection="channelUserIdList" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </select>
    <select id="queryMap" resultType="java.util.Map" parameterType="java.util.List">
        SELECT
            user_id AS userId,
            amount as usdtBalanceAmount
        FROM t_user_wallet
        WHERE currency_id = 6
        AND user_id IN
        <foreach collection="userIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
