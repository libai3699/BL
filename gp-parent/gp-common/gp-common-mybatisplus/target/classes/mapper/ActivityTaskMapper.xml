<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.ActivityTaskMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.ActivityTask" id="ActivityTaskResult">
        <result property="id"    column="id"    />
        <result property="activityId"    column="activity_id"    />
        <result property="type"    column="type"    />
        <result property="timeType"    column="time_type"    />
        <result property="taskAmount"    column="task_amount"    />
        <result property="status"    column="status"    />
        <result property="sort"    column="sort"    />
        <result property="taskName"    column="task_name"    />
        <result property="createTime"    column="create_time"    />
        <result property="createBy"    column="create_by"    />
    </resultMap>

    <sql id="selectActivityTaskVo">
        select id, activity_id, type, time_type, task_amount, status, sort,task_name, create_time, create_by from t_activity_task
    </sql>

    <select id="selectActivityTaskList" parameterType="com.gp.common.mybatisplus.entity.ActivityTask" resultMap="ActivityTaskResult">
        <include refid="selectActivityTaskVo"/>
        <where>
            <if test="id != null ">and id = #{id}</if>
            <if test="activityId != null ">and activity_id = #{activityId}</if>
            <if test="type != null ">and type = #{type}</if>
            <if test="timeType != null ">and time_type = #{timeType}</if>
            <if test="taskAmount != null ">and task_amount = #{taskAmount}</if>
            <if test="status != null ">and status = #{status}</if>
            <if test="sort != null ">and sort = #{sort}</if>
            <if test="taskName != null and taskName != '' ">and task_name = #{taskName}</if>
            <if test="createTimes != null and createTimes.length > 0">
                and (
                <foreach collection="createTimes" item="item" index="index">
                    <if test="index == 0">
                        create_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="createBy != null  and createBy != ''">and create_by = #{createBy}</if>
        </where>
    </select>

    <select id="selectActivityTaskListCount" parameterType="com.gp.common.mybatisplus.entity.ActivityTask" resultType="java.lang.Integer">
        select count(*) from (
            <include refid="selectActivityTaskVo"/>
            <where>
                <if test="id != null ">and id = #{id}</if>
                <if test="activityId != null ">and activity_id = #{activityId}</if>
                <if test="type != null ">and type = #{type}</if>
                <if test="timeType != null ">and time_type = #{timeType}</if>
                <if test="taskAmount != null ">and task_amount = #{taskAmount}</if>
                <if test="status != null ">and status = #{status}</if>
                <if test="sort != null ">and sort = #{sort}</if>
                <if test="taskName != null and taskName != '' ">and task_name = #{taskName}</if>
                <if test="createTimes != null and createTimes.length > 0">
                    and (
                    <foreach collection="createTimes" item="item" index="index">
                        <if test="index == 0">
                            create_time between #{item,jdbcType=VARCHAR}
                        </if>
                        <if test="index == 1">
                            and #{item,jdbcType=VARCHAR}
                        </if>
                    </foreach>
                    )
                </if>
                <if test="createBy != null  and createBy != ''">and create_by = #{createBy}</if>
            </where>
        ) as tmp
    </select>

    <select id="selectActivityTaskById" parameterType="Long" resultMap="ActivityTaskResult">
        <include refid="selectActivityTaskVo"/>
        where id = #{id}
    </select>

    <insert id="insertActivityTask" parameterType="com.gp.common.mybatisplus.entity.ActivityTask" useGeneratedKeys="true" keyProperty="id">
        insert into t_activity_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="activityId != null ">activity_id,</if>
            <if test="type != null ">type,</if>
            <if test="timeType != null ">time_type,</if>
            <if test="taskAmount != null ">task_amount,</if>
            <if test="status != null ">status,</if>
            <if test="sort != null ">sort,</if>
            <if test="taskName != null and taskName != '' ">task_name,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="activityId != null ">#{activityId},</if>
            <if test="type != null ">#{type},</if>
            <if test="timeType != null ">#{timeType},</if>
            <if test="taskAmount != null ">#{taskAmount},</if>
            <if test="status != null ">#{status},</if>
            <if test="sort != null ">#{sort},</if>
            <if test="taskName != null and taskName != '' ">#{taskName},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
         </trim>
    </insert>

    <update id="updateActivityTask" parameterType="com.gp.common.mybatisplus.entity.ActivityTask">
        update t_activity_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="activityId != null ">activity_id = #{activityId},</if>
            <if test="type != null ">type = #{type},</if>
            <if test="timeType != null ">time_type = #{timeType},</if>
            <if test="taskAmount != null ">task_amount = #{taskAmount},</if>
            <if test="status != null ">status = #{status},</if>
            <if test="sort != null ">sort = #{sort},</if>
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteActivityTaskById" parameterType="Long">
        delete from t_activity_task where id = #{id}
    </delete>

    <delete id="deleteActivityTaskByIds" parameterType="String">
        delete from t_activity_task where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_activity_task
    </update>
</mapper>
