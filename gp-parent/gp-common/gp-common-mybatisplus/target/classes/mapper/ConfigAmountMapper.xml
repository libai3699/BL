<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.ConfigAmountMapper">
    <resultMap type="com.gp.common.mybatisplus.entity.ConfigAmount" id="ConfigAmountResult">
        <result property="configId" column="config_id"/>
        <result property="configName" column="config_name"/>
        <result property="configKey" column="config_key"/>
        <result property="configValue" column="config_value"/>
        <result property="signTime" column="sign_time"/>
        <result property="sign" column="sign"/>
        <result property="createTime" column="create_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="isShow"    column="is_show"    />

    </resultMap>

    <sql id="selectConfigAmountVo">
        select config_id,
               config_name,
               config_key,
               config_value,
               create_time,
               create_by,
               update_time,
               update_by,
               sign,
               sign_time,
               is_show
        from t_config_amount
    </sql>

    <select id="selectConfigAmountList" parameterType="com.gp.common.mybatisplus.entity.ConfigAmount"
            resultMap="ConfigAmountResult">
        <include refid="selectConfigAmountVo"/>
        <where>
            <if test="configName != null  and configName != ''">and config_name like concat('%', #{configName}, '%')
            </if>
            <if test="configKey != null  and configKey != ''">and config_key = #{configKey}</if>
            <if test="configValue != null  and configValue != ''">and config_value = #{configValue}</if>
            <if test="signTime != null ">and sign_time = #{signTime}</if>
            <if test="sign != null  and sign != ''">and sign = #{sign}</if>
            <if test="createTimes != null and createTimes.length > 0">and (
                <foreach collection="createTimes" item="item" index="index">
                    <if test="index == 0">
                        create_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="createBy != null  and createBy != ''">and create_by = #{createBy}</if>

            <if test="updateTimes != null and updateTimes.length > 0">and (
                <foreach collection="updateTimes" item="item" index="index">
                    <if test="index == 0">
                        update_time between #{item,jdbcType=VARCHAR}
                    </if>
                    <if test="index == 1">
                        and #{item,jdbcType=VARCHAR}
                    </if>
                </foreach>
                )
            </if>
            <if test="updateBy != null  and updateBy != ''">and update_by = #{updateBy}</if>
            <if test="isShow != null "> and is_show = #{isShow}</if>
        </where>
    </select>

    <select id="selectConfigAmountById" parameterType="Integer" resultMap="ConfigAmountResult">
        <include refid="selectConfigAmountVo"/>
        where config_id = #{configId}
    </select>

    <insert id="insertConfigAmount" parameterType="com.gp.common.mybatisplus.entity.ConfigAmount"
            useGeneratedKeys="true" keyProperty="configId">
        insert into t_config_amount
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null  and configName != ''">config_name,</if>
            <if test="configKey != null  and configKey != ''">config_key,</if>
            <if test="configValue != null  and configValue != ''">config_value,</if>
            <if test="signTime != null">sign_time,</if>
            <if test="sign != null  and sign != ''">sign,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>

            <if test="updateTime != null ">update_time,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
            <if test="isShow != null ">is_show,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null  and configName != ''">#{configName},</if>
            <if test="configKey != null  and configKey != ''">#{configKey},</if>
            <if test="configValue != null  and configValue != ''">#{configValue},</if>
            <if test="signTime != null">#{signTime},</if>
            <if test="sign != null  and sign != ''">#{sign},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
            <if test="updateTime != null ">#{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">#{updateBy},</if>
            <if test="isShow != null ">#{isShow},</if>
        </trim>
    </insert>

    <update id="updateConfigAmount" parameterType="com.gp.common.mybatisplus.entity.ConfigAmount">
        update t_config_amount
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null  and configName != ''">config_name = #{configName},</if>
            <if test="configKey != null  and configKey != ''">config_key = #{configKey},</if>
            <if test="configValue != null  and configValue != ''">config_value = #{configValue},</if>
            <if test="signTime != null ">sign_time = #{signTime},</if>
            <if test="sign != null  and sign != ''">sign = #{sign},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            87
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
            <if test="isShow != null ">is_show = #{isShow},</if>
        </trim>
        where config_id = #{configId}
    </update>

    <delete id="deleteConfigAmountById" parameterType="Integer">
        delete
        from t_config_amount
        where config_id = #{configId}
    </delete>

    <delete id="deleteConfigAmountByIds" parameterType="String">
        delete from t_config_amount where config_id in
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_config_amount
    </update>
    <update id="updateIsDispById" parameterType="com.gp.common.mybatisplus.entity.ConfigAmount">
         update t_config_amount set is_show = #{isShow} where config_id = #{configId}
    </update>
</mapper>
