<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.DifferentialLevelMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.DifferentialLevel" id="DifferentialLevelResult">
        <result property="id"    column="id"    />
        <result property="minActiveCount"    column="min_active_count"    />
        <result property="codeAmount"    column="code_amount"    />
        <result property="salaryRate"    column="salary_rate"    />
        <result property="createTime"    column="create_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="updateBy"    column="update_by"    />
    </resultMap>

    <sql id="selectDifferentialLevelVo">
        select id, min_active_count, code_amount, salary_rate, create_time, create_by, update_time, update_by from t_differential_level
    </sql>

    <select id="selectDifferentialLevelList" parameterType="com.gp.common.mybatisplus.entity.DifferentialLevel" resultMap="DifferentialLevelResult">
        <include refid="selectDifferentialLevelVo"/>
        <where>
    <if test="minActiveCount != null "> and min_active_count = #{minActiveCount}</if>
    <if test="codeAmount != null "> and code_amount = #{codeAmount}</if>
    <if test="salaryRate != null "> and salary_rate = #{salaryRate}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
        </where>
    </select>

    <select id="selectDifferentialLevelById" parameterType="Long" resultMap="DifferentialLevelResult">
        <include refid="selectDifferentialLevelVo"/>
        where id = #{id}
    </select>

    <insert id="insertDifferentialLevel" parameterType="com.gp.common.mybatisplus.entity.DifferentialLevel" useGeneratedKeys="true" keyProperty="id">
        insert into t_differential_level
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="minActiveCount != null ">min_active_count,</if>
            <if test="codeAmount != null ">code_amount,</if>
            <if test="salaryRate != null ">salary_rate,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
            <if test="updateTime != null ">update_time,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="minActiveCount != null ">#{minActiveCount},</if>
            <if test="codeAmount != null ">#{codeAmount},</if>
            <if test="salaryRate != null ">#{salaryRate},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
            <if test="updateTime != null ">#{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">#{updateBy},</if>
         </trim>
    </insert>

    <update id="updateDifferentialLevel" parameterType="com.gp.common.mybatisplus.entity.DifferentialLevel">
        update t_differential_level
        <trim prefix="SET" suffixOverrides=",">
            <if test="minActiveCount != null ">min_active_count = #{minActiveCount},</if>
            <if test="codeAmount != null ">code_amount = #{codeAmount},</if>
            <if test="salaryRate != null ">salary_rate = #{salaryRate},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteDifferentialLevelById" parameterType="Long">
        delete from t_differential_level where id = #{id}
    </delete>

    <delete id="deleteDifferentialLevelByIds" parameterType="String">
        delete from t_differential_level where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_differential_level
    </update>
</mapper>
