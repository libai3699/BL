<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.DomainConfigMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.DomainConfig" id="DomainConfigResult">
        <result property="id"    column="id"    />
        <result property="domainName"    column="domain_name"    />
        <result property="domainType"    column="domain_type"    />
        <result property="regionCode"    column="region_code"    />
        <result property="sort"    column="sort"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectDomainConfigVo">
        select id, domain_name, domain_type, region_code, sort, status, create_by, create_time, update_by, update_time from t_domain_config
    </sql>

    <select id="selectDomainConfigList" parameterType="com.gp.common.mybatisplus.entity.DomainConfig" resultMap="DomainConfigResult">
        <include refid="selectDomainConfigVo"/>
        <where>
            <if test="domainName != null  and domainName != ''"> and domain_name like concat('%', #{domainName}, '%')</if>
    <if test="domainType != null "> and domain_type = #{domainType}</if>
    <if test="regionCode != null  and regionCode != ''"> and region_code = #{regionCode}</if>
    <if test="sort != null "> and sort = #{sort}</if>
    <if test="status != null "> and status = #{status}</if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
        </where>
    </select>

    <select id="selectDomainConfigById" parameterType="Long" resultMap="DomainConfigResult">
        <include refid="selectDomainConfigVo"/>
        where id = #{id}
    </select>

    <insert id="insertDomainConfig" parameterType="com.gp.common.mybatisplus.entity.DomainConfig" useGeneratedKeys="true" keyProperty="id">
        insert into t_domain_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="domainName != null  and domainName != ''">domain_name,</if>
            <if test="domainType != null ">domain_type,</if>
            <if test="regionCode != null  and regionCode != ''">region_code,</if>
            <if test="sort != null ">sort,</if>
            <if test="status != null ">status,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
            <if test="updateTime != null ">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="domainName != null  and domainName != ''">#{domainName},</if>
            <if test="domainType != null ">#{domainType},</if>
            <if test="regionCode != null  and regionCode != ''">#{regionCode},</if>
            <if test="sort != null ">#{sort},</if>
            <if test="status != null ">#{status},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="updateBy != null  and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null ">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateDomainConfig" parameterType="com.gp.common.mybatisplus.entity.DomainConfig">
        update t_domain_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="domainName != null  and domainName != ''">domain_name = #{domainName},</if>
            <if test="domainType != null ">domain_type = #{domainType},</if>
            <if test="regionCode != null  and regionCode != ''">region_code = #{regionCode},</if>
            <if test="sort != null ">sort = #{sort},</if>
            <if test="status != null ">status = #{status},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteDomainConfigById" parameterType="Long">
        delete from t_domain_config where id = #{id}
    </delete>

    <delete id="deleteDomainConfigByIds" parameterType="String">
        delete from t_domain_config where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_domain_config
    </update>
</mapper>
