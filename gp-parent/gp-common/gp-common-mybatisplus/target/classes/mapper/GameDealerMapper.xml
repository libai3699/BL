    <sql id="selectGameDealerVo">
        select dealer_id, dealer_code, dealer_name,  category, dealer_info, dealer_content, create_time, create_by, update_time, update_by from t_game_dealer
    </sql>

    <select id="selectGameDealerList" parameterType="com.gp.common.mybatisplus.entity.GameDealer" resultMap="GameDealerResult">
        <include refid="selectGameDealerVo"/>
        <where>
    <if test="dealerCode != null  and dealerCode != ''"> and dealer_code = #{dealerCode}</if>
    <if test="dealerName != null  and dealerName != ''"> and dealer_name = #{dealerName}</if>
    <if test="category != null  and category != ''"> and category = #{category}</if>
    <if test="dealerInfo != null  and dealerInfo != ''"> and dealer_info = #{dealerInfo}</if>
    <if test="dealerContent != null  and dealerContent != ''"> and dealer_content = #{dealerContent}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
        </where>
    </select>
    
