    <select id="queryGameByTag" resultType="com.gp.common.mybatisplus.entity.Game">
        select g.*
        from t_game g
        inner join t_game_plate p on p.plate_code = g.plate_code and p.status = 1
        where g.game_type_code = #{typeCode} and g.status = 1
        <if test="plateName != null and plateName != ''">
            and g.category = #{plateName}
        </if>
        order by p.is_maint,
        <if test="plateName != null and plateName != ''">g.plate_sort,</if>
        g.sort, g.id
    </select>
    <select id="queryHot" resultType="com.gp.common.mybatisplus.entity.Game">
        select g.*
        from t_game g
        inner join t_game_plate p on p.plate_code = g.plate_code and p.status = 1
        where g.status = 1 and g.is_hot = 1
        order by p.is_maint, g.hot_sort, g.sort, g.id
    </select>
    <select id="queryGameCondition" resultType="com.gp.common.mybatisplus.entity.Game">
        select g.*
        from t_game g
        inner join t_game_plate p on p.plate_code = g.plate_code and p.status = 1
        where g.status = 1
        <if test="plateName != null and plateName != ''">
            and g.category = #{plateName}
        </if>
        <if test="typeCode != null and typeCode != 0">
            and g.game_type_code = #{typeCode}
        </if>
<!--        <if test="rank != null and rank == 0">-->
<!--            and g.is_hot = 1-->
<!--        </if>-->
        <if test="arr != null and arr.size() > 0">
            and g.id in
            <foreach item="id" collection="arr" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="keyWord != null and keyWord != ''">
            and (g.game_name_zh like CONCAT('%', #{keyWord}, '%')
            or g.game_name_en like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ko like CONCAT('%', #{keyWord}, '%')
            or g.game_name_pt like CONCAT('%', #{keyWord}, '%')
            or g.game_name_vi like CONCAT('%', #{keyWord}, '%')
            or g.game_name_tr like CONCAT('%', #{keyWord}, '%')
            or g.game_name_tw like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ja like CONCAT('%', #{keyWord}, '%')
            or g.game_name_hi like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ru like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ar like CONCAT('%', #{keyWord}, '%')
            )
        </if>
        order by p.is_maint,
        <if test="plateName != null and plateName != ''">g.plate_sort,</if>
        g.sort, g.id
    </select>
    <!--    0 最新 1 热门电子-->
    <select id="queryNewGameOrHot" resultType="com.gp.common.mybatisplus.entity.Game">
        select g.*
        from t_game g
        inner join t_game_plate p on p.plate_code = g.plate_code and p.status = 1
        where g.status = 1
        <if test="plateName != null and plateName != ''">
            and g.category = #{plateName}
        </if>
        <if test="typeCode != null and typeCode != '0'">
            and g.game_type_code = #{typeCode}
        </if>
<!--        <if test="rank != null and rank == 0">-->
<!--            and g.is_hot = 1-->
<!--        </if>-->
        <if test="type != null and type == 0">
            and g.is_new_game = 1
        </if>
        <if test="type != null and type == 1">
            and g.is_hot = 1
        </if>
        <if test="arr != null and arr.size() > 0">
            and g.id in
            <foreach item="id" collection="arr" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="keyWord != null and keyWord != ''">
            and (g.game_name_zh like CONCAT('%', #{keyWord}, '%')
            or g.game_name_en like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ko like CONCAT('%', #{keyWord}, '%')
            or g.game_name_pt like CONCAT('%', #{keyWord}, '%')
            or g.game_name_vi like CONCAT('%', #{keyWord}, '%')
            or g.game_name_tr like CONCAT('%', #{keyWord}, '%')
            or g.game_name_tw like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ja like CONCAT('%', #{keyWord}, '%')
            or g.game_name_hi like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ru like CONCAT('%', #{keyWord}, '%')
            or g.game_name_ar like CONCAT('%', #{keyWord}, '%')
            )
        </if>
        order by p.is_maint,
        <choose>
            <when test="type == 1">g.hot_sort,</when>
            <when test="plateName != null and plateName != ''">g.plate_sort,</when>
        </choose>
        g.sort, g.id
    </select>
    <select id="randomGame" resultType="com.gp.common.mybatisplus.entity.Game"
            parameterType="java.lang.Integer">
        SELECT game.*
        FROM (
                 SELECT g.*
                 FROM t_game g
                 INNER JOIN t_game_plate p ON p.plate_code = g.plate_code AND p.status = 1
                 WHERE g.status = 1 AND g.is_hot = 1
                 ORDER BY g.plate_sort, g.sort, g.id
                 LIMIT 100
             ) AS game
        ORDER BY RAND()
        LIMIT #{limit}
    </select>

<!--    0 最新  1 热门电子-->
    <select id="queryNewOrHotGamePlate" resultType="java.lang.String">
        select DISTINCT plate_code from t_game
            <where>
                <if test="type = 0">
                    and is_new_game = 1
                </if>
                <if test="type = 1">
                    and is_hot = 1
                    and game_type_code = 1
                </if>
            </where>


    </select>
