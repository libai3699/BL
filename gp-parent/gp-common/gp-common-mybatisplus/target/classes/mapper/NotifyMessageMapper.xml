<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.NotifyMessageMapper">
  <resultMap id="BaseResultMap" type="com.gp.common.mybatisplus.entity.NotifyMessage">
    <!--@mbg.generated-->
    <!--@Table t_user_message-->
    <id column="id" jdbcType="BIGINT" property="id" />
    <result column="lan_key" jdbcType="VARCHAR" property="lanKey" />
    <result column="title" jdbcType="VARCHAR" property="title" />
    <result column="content" jdbcType="VARCHAR" property="content" />
    <result column="remark" jdbcType="VARCHAR" property="remark" />
    <result column="create_by" jdbcType="VARCHAR" property="createBy" />
    <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
  </resultMap>

  <sql id="selectNotifyMessageVo">
    select id, lan_key,title,content, remark, create_by, create_time from t_notify_message
  </sql>
  <select id="selectNotifyMessageList" parameterType="com.gp.common.mybatisplus.entity.NotifyMessage" resultMap="BaseResultMap">
    <include refid="selectNotifyMessageVo"/>
    <where>
      <if test="lanKey != null  and lanKey != ''"> and lan_key = #{lanKey}</if>
      <if test="title != null  and title != ''"> and title like concat('%', #{title}, '%')</if>
      <if test="content != null  and content != ''"> and content like concat('%', #{content}, '%')</if>
      <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
          <if test="index == 0">
            create_time between #{item,jdbcType=VARCHAR}
          </if>
          <if test="index == 1">
            and #{item,jdbcType=VARCHAR}
          </if>
        </foreach>
        )
      </if>
    </where>
  </select>


</mapper>
