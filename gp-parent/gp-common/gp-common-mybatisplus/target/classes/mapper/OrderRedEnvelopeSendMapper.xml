    <update id="updateByeReceive">
        UPDATE `t_order_red_envelope_send`
        set last_amount = (last_amount - #{amount}),
        last_num = (last_num - 1),
        status = IF(last_num = 0, 2, status),
        end_time = IF(last_num = 0, now(), end_time),
        sign_time = #{signTime},
        sign = TO_BASE64(MD5((CONCAT(MD5(CONCAT(order_no, '&amp;', currency_id, '&amp;', TRIM(TRAILING '.'
        from(TRIM(TRAILING '0' FROM amount))), '&amp;', user_id,'&amp;', user_tg_id,'&amp;',status,'&amp;',
        TRIM(TRAILING '.' from(TRIM(TRAILING '0' FROM last_amount))),'&amp;',
        #{signTime},#{signSecretKey})),#{signSecretKey}))))
        <where>
            id = #{id} and last_amount - #{amount} >= 0
        </where>
    </update>

