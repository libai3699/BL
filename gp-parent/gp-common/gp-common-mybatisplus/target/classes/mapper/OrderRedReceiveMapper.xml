            <if test="userId != null ">#{userId},</if>
            <if test="userTgId != null ">#{userTgId},</if>
            <if test="userName != null  and userName != ''">#{userName},</if>
            <if test="amount != null ">#{amount},</if>
            <if test="signTime != null ">#{signTime},</if>
            <if test="sign != null  and sign != ''">#{sign},</if>
            <if test="createTime != null ">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateOrderRedReceive" parameterType="com.gp.common.mybatisplus.entity.OrderRedReceive">
        update t_order_red_receive
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null  and orderNo != ''">order_no = #{orderNo},</if>
            <if test="linkId != null ">link_id = #{linkId},</if>
            <if test="type != null ">type = #{type},</if>
            <if test="currencyId != null ">currency_id = #{currencyId},</if>
            <if test="itemId != null ">item_id = #{itemId},</if>
            <if test="chainTag != null  and chainTag != ''">chain_tag = #{chainTag},</if>
            <if test="itemName != null  and itemName != ''">item_name = #{itemName},</if>
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="userTgId != null ">user_tg_id = #{userTgId},</if>
            <if test="userName != null  and userName != ''">user_name = #{userName},</if>
            <if test="amount != null ">amount = #{amount},</if>
            <if test="signTime != null ">sign_time = #{signTime},</if>
            <if test="sign != null  and sign != ''">sign = #{sign},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOrderRedReceiveById" parameterType="Long">
        delete from t_order_red_receive where id = #{id}
    </delete>

    <delete id="deleteOrderRedReceiveByIds" parameterType="String">
        delete from t_order_red_receive where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_order_red_receive
    </update>


    <select id="redEnvelopeRainCountMap" resultType="java.util.Map">
        select
        count(CASE WHEN type = 1 THEN 1 END) as redNum,
        IFNULL(SUM(CASE WHEN type = 1 THEN amount ELSE 0 END),0) as redAmount,
        count(CASE WHEN type = 2 THEN 1 END) as redPrivateNum,
        IFNULL(SUM(CASE WHEN type = 2 THEN amount ELSE 0 END),0) as redPrivateAmount,
        IFNULL(SUM(amount), 0) as totalRedAmount
        from t_order_red_receive
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="currencyId != null">
                AND currency_id = #{currencyId}
            </if>
            <if test="startTime != null and endTime != null">
                AND create_time BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>
    </select>

    <select id="redEnvelopeRainChanneCountMap" resultType="java.util.Map">
        SELECT
        COUNT(*) AS counts,
        IFNULL(SUM(temp.amount), 0) AS amount
        FROM (
        SELECT a.amount, a.user_id
        FROM t_order_red_receive a
        <where>
            <if test="currencyId != null">
                AND a.currency_id = #{currencyId}
            </if>
            <if test="startTime != null and endTime != null">
                AND a.create_time BETWEEN #{startTime} AND #{endTime}
            </if>
            <if test="type != null">
                AND a.type = #{type}
            </if>
        </where>
        ) temp
        LEFT JOIN t_user u ON temp.user_id = u.user_id
        <where>
            <if test="channelId != null">
                AND u.channel_id = #{channelId}
            </if>
        </where>
    </select>
</mapper>
