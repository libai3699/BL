<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.PayBlockchainMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.PayBlockchain" id="PayBlockchainResult">
        <result property="id"    column="id"    />
        <result property="icon"    column="icon"    />
        <result property="chain"    column="chain"    />
        <result property="item"    column="item"    />
        <result property="platformRate"    column="platform_rate"    />
        <result property="addr"    column="addr"    />
        <result property="notice"    column="notice"    />
        <result property="withdrawNotice"    column="withdraw_notice"    />
        <result property="status"    column="status"    />
        <result property="isRecharge"    column="is_recharge"    />
        <result property="isWithdraw"    column="is_withdraw"    />
        <result property="sort"    column="sort"    />
        <result property="createTime"    column="create_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="updateBy"    column="update_by"    />
    </resultMap>

    <sql id="selectPayBlockchainVo">
        select id, icon, chain, item, platform_rate, addr, notice, withdraw_notice, status, is_recharge, is_withdraw, sort, create_time, create_by, update_time, update_by from t_pay_blockchain
    </sql>

    <select id="selectPayBlockchainList" parameterType="com.gp.common.mybatisplus.entity.PayBlockchain" resultMap="PayBlockchainResult">
        <include refid="selectPayBlockchainVo"/>
        <where>
    <if test="icon != null  and icon != ''"> and icon = #{icon}</if>
    <if test="chain != null  and chain != ''"> and chain = #{chain}</if>
    <if test="item != null  and item != ''"> and item = #{item}</if>
    <if test="addr != null  and addr != ''"> and addr = #{addr}</if>
    <if test="notice != null  and notice != ''"> and notice = #{notice}</if>
    <if test="withdrawNotice != null  and withdrawNotice != ''"> and withdraw_notice = #{withdrawNotice}</if>
    <if test="platformRate != null"> and platform_rate = #{platformRate}</if>
    <if test="status != null"> and status = #{status}</if>
    <if test="isRecharge != null"> and is_recharge = #{isRecharge}</if>
    <if test="isWithdraw != null"> and is_withdraw = #{isWithdraw}</if>
     <if test="sort != null"> and sort = #{sort}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
        </where>
    </select>

    <select id="selectPayBlockchainById" parameterType="Integer" resultMap="PayBlockchainResult">
        <include refid="selectPayBlockchainVo"/>
        where id = #{id}
    </select>


</mapper>
