<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gp.common.mybatisplus.mapper.UserPayMethodMapper">

    <resultMap type="com.gp.common.mybatisplus.entity.UserPayMethod" id="UserPayMethodResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="payTypeId"    column="pay_type_id"    />
        <result property="payTypeCode"    column="pay_type_code"    />
        <result property="bindData"    column="bind_data"  typeHandler="com.baomidou.mybatisplus.extension.handlers.FastjsonTypeHandler"/>
        <result property="isDefault"    column="is_default"    />
        <result property="sort"    column="sort"    />
        <result property="createTime"    column="create_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="updateBy"    column="update_by"    />
    </resultMap>

    <sql id="selectUserPayMethodVo">
        select id, user_id, pay_type_id, pay_type_code, bind_data, is_default, sort, create_time, create_by, update_time, update_by from t_user_pay_method
    </sql>

    <select id="selectUserPayMethodList" parameterType="com.gp.common.mybatisplus.entity.UserPayMethod" resultMap="UserPayMethodResult">
        <include refid="selectUserPayMethodVo"/>
        <where>
    <if test="userId != null "> and user_id = #{userId}</if>
    <if test="payTypeId != null "> and pay_type_id = #{payTypeId}</if>
    <if test="payTypeCode != null  and payTypeCode != ''"> and pay_type_code = #{payTypeCode}</if>
    <if test="bindData != null  and bindData != ''"> and bind_data = #{bindData}</if>
    <if test="isDefault != null "> and is_default = #{isDefault}</if>
    <if test="sort != null "> and sort = #{sort}</if>
    <if test="createTimes != null and createTimes.length > 0">
        and (
        <foreach collection="createTimes" item="item" index="index">
            <if test="index == 0">
                create_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
    <if test="updateTimes != null and updateTimes.length > 0">
        and (
        <foreach collection="updateTimes" item="item" index="index">
            <if test="index == 0">
                update_time between #{item,jdbcType=VARCHAR}
            </if>
            <if test="index == 1">
                and #{item,jdbcType=VARCHAR}
            </if>
        </foreach>
        )
    </if>
    <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
        </where>
    </select>

    <select id="selectUserPayMethodById" parameterType="Long" resultMap="UserPayMethodResult">
        <include refid="selectUserPayMethodVo"/>
        where id = #{id}
    </select>

    <insert id="insertUserPayMethod" parameterType="com.gp.common.mybatisplus.entity.UserPayMethod" useGeneratedKeys="true" keyProperty="id">
        insert into t_user_pay_method
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null ">user_id,</if>
            <if test="payTypeId != null ">pay_type_id,</if>
            <if test="payTypeCode != null  and payTypeCode != ''">pay_type_code,</if>
            <if test="bindData != null ">bind_data,</if>
            <if test="isDefault != null ">is_default,</if>
            <if test="sort != null ">sort,</if>
            <if test="createTime != null ">create_time,</if>
            <if test="createBy != null  and createBy != ''">create_by,</if>
            <if test="updateTime != null ">update_time,</if>
            <if test="updateBy != null  and updateBy != ''">update_by,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null ">#{userId},</if>
            <if test="payTypeId != null ">#{payTypeId},</if>
            <if test="payTypeCode != null  and payTypeCode != ''">#{payTypeCode},</if>
            <if test="bindData != null ">#{bindData,typeHandler=com.baomidou.mybatisplus.extension.handlers.FastjsonTypeHandler},</if>

            <if test="isDefault != null ">#{isDefault},</if>
            <if test="sort != null ">#{sort},</if>
            <if test="createTime != null ">#{createTime},</if>
            <if test="createBy != null  and createBy != ''">#{createBy},</if>
            <if test="updateTime != null ">#{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">#{updateBy},</if>
         </trim>
    </insert>

    <update id="updateUserPayMethod" parameterType="com.gp.common.mybatisplus.entity.UserPayMethod">
        update t_user_pay_method
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null ">user_id = #{userId},</if>
            <if test="payTypeId != null ">pay_type_id = #{payTypeId},</if>
            <if test="payTypeCode != null  and payTypeCode != ''">pay_type_code = #{payTypeCode},</if>
            <if test="bindData != null ">bind_data = #{bind_data,typeHandler=com.baomidou.mybatisplus.extension.handlers.FastjsonTypeHandler},</if>

            <if test="isDefault != null ">is_default = #{isDefault},</if>
            <if test="sort != null ">sort = #{sort},</if>
            <if test="createTime != null ">create_time = #{createTime},</if>
            <if test="createBy != null  and createBy != ''">create_by = #{createBy},</if>
            <if test="updateTime != null ">update_time = #{updateTime},</if>
            <if test="updateBy != null  and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUserPayMethodById" parameterType="Long">
        delete from t_user_pay_method where id = #{id}
    </delete>

    <delete id="deleteUserPayMethodByIds" parameterType="String">
        delete from t_user_pay_method where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="truncate">
        truncate table t_user_pay_method
    </update>
</mapper>
