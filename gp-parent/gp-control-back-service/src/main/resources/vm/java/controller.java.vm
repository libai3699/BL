package ${packageName}.controller;

import java.util.List;
import com.gp.common.utils.SecurityUtils;
import io.swagger.annotations.Api;
import io.swagger.annotations.ApiImplicitParam;
import io.swagger.annotations.ApiImplicitParams;
import io.swagger.annotations.ApiOperation;
import com.common.core.result.AjaxResult;
import com.gp.common.mybatisplus.excel.poi.ExcelUtil;
import cn.licoy.encryptbody.annotation.encrypt.AESEncryptBody;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;
import com.gp.framework.aspectj.lang.annotation.Log;
import com.gp.framework.aspectj.lang.enums.BusinessType;
import ${mapperName}.entity.${ClassName};
import ${mapperName}.service.${ClassName}Service;
import com.gp.framework.web.controller.BaseController;
#if($table.crud)
import com.gp.framework.web.page.TableDataInfo;
#elseif($table.tree)
#end

/**
 * ${functionName}管理
 *
 * @author ${author}
 * @date ${datetime}
 */
@AESEncryptBody
@Api(tags = "${functionName}Controller")
@RestController
@RequestMapping("/${moduleName}/${businessName}")
public class ${ClassName}Controller extends BaseController
{
    @Autowired
    private ${ClassName}Service ${className}Service;

    /**
     * 查询${functionName}列表
     */
    @ApiOperation(value = "查询${functionName}列表", notes = "备注: 无")
    @PreAuthorize("@ss.hasPermi('${permissionPrefix}:list')")
    @PostMapping("/list")
#if($table.crud)
    public TableDataInfo list(@RequestBody ${ClassName} param)
    {
        startPage();
        List<${ClassName}> list = ${className}Service.select${ClassName}List(param);
        return getDataTable(list);
    }
#elseif($table.tree)
    public AjaxResult list(${ClassName} param)
    {
        List<${ClassName}> list = ${className}Service.select${ClassName}List(param);
        return AjaxResult.success(list);
    }
#end

    /**
     * 导出${functionName}列表
     */
    @ApiOperation(value = "导出${functionName}列表", notes = "备注: 无")
    @PreAuthorize("@ss.hasPermi('${permissionPrefix}:export')")
    @Log(title = "${functionName}", businessType = BusinessType.EXPORT)
    @PostMapping("/export")
    public AjaxResult export(@RequestBody ${ClassName} param)
    {
        List<${ClassName}> list = ${className}Service.select${ClassName}List(param);
        ExcelUtil<${ClassName}> util = new ExcelUtil<${ClassName}>(${ClassName}.class);
        return util.exportExcel(list, "${businessName}");
    }

    /**
     * 获取${functionName}详细信息
     */
    @ApiOperation(value = "获取${functionName}详细信息", notes = "备注: 无")
    @ApiImplicitParams({
            @ApiImplicitParam(name="${pkColumn.javaField}",value="Id",required=true,paramType="${pkColumn.javaType}"),
    })
    @PreAuthorize("@ss.hasPermi('${permissionPrefix}:query')")
    @GetMapping(value = "/getInfo/{${pkColumn.javaField}}")
    public AjaxResult getInfo(@PathVariable("${pkColumn.javaField}") ${pkColumn.javaType} ${pkColumn.javaField})
    {
        return AjaxResult.success(${className}Service.select${ClassName}ById(${pkColumn.javaField}));
    }

    /**
     * 新增${functionName}
     */
    @ApiOperation(value = "新增${functionName}", notes = "备注: 无")
    @PreAuthorize("@ss.hasPermi('${permissionPrefix}:add')")
    @Log(title = "${functionName}", businessType = BusinessType.INSERT)
    @PostMapping("/add")
    public AjaxResult add(@RequestBody ${ClassName} param)
    {
        param.setCreateBy(SecurityUtils.getUsername());
        return toAjax(${className}Service.insert${ClassName}(param));
    }

    /**
     * 修改${functionName}
     */
    @ApiOperation(value = "修改${functionName}", notes = "备注: 无")
    @PreAuthorize("@ss.hasPermi('${permissionPrefix}:edit')")
    @Log(title = "${functionName}", businessType = BusinessType.UPDATE)
    @PostMapping("/edit")
    public AjaxResult edit(@RequestBody ${ClassName} param)
    {
        param.setUpdateBy(SecurityUtils.getUsername());
        return toAjax(${className}Service.update${ClassName}(param));
    }

    /**
     * 删除${functionName}
     */
    @ApiOperation(value = "删除${functionName}", notes = "备注: 无")
    @ApiImplicitParams({
            @ApiImplicitParam(name="${pkColumn.javaField}s",value="Id数组",required=true,paramType="${pkColumn.javaType}[]"),
    })
    @PreAuthorize("@ss.hasPermi('${permissionPrefix}:remove')")
    @Log(title = "${functionName}", businessType = BusinessType.DELETE)
	@PostMapping("/delete/{${pkColumn.javaField}s}")
    public AjaxResult remove(@PathVariable ${pkColumn.javaType}[] ${pkColumn.javaField}s)
    {
        return toAjax(${className}Service.delete${ClassName}ByIds(${pkColumn.javaField}s));
    }
}
