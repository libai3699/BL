// 导出${functionName}
export function export${BusinessName}(query) {
    var pageNum = query.pageNum;
    var pageSize = query.pageSize;
    var orderByColumn = query.orderByColumn;
    var isAsc = query.isAsc;
  return request({
    url: '/${moduleName}/${businessName}/export'+'?pageNum='+pageNum+'&pageSize='+pageSize+'&orderByColumn='+orderByColumn+'&isAsc='+isAsc,
    method: 'post',
    data: query
  })
}
