{
	"easycom": {
		// 注意一定要放在custom里，否则无效，https://ask.dcloud.net.cn/question/131175
		"custom": {
			"^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
			"^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
			"^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue",
			"^c-popup-([^-].*)": "/src/components/c-popup/$1.vue",
			"^stock-item$": "/src/components/stock-item/index.vue",
			"^news-item$": "/src/components/news-item/index.vue",
			"^password-input$": "/src/components/password-input/index.vue",
			"^maintenance-box$": "/src/components/maintenance-box/maintenance-box.vue",
			"^err-illustration$": "/src/components/err-illustration/err-illustration.vue",
			"^tab-bar-center-btn$": "/src/components/tab-bar-center-btn/tab-bar-center-btn.vue",
			"^trade-bottom-sheet$": "/src/components/trade-bottom-sheet/trade-bottom-sheet.vue"
		}
	},
